        // Formats the average value to 1 decimal place using strict BigDecimal rounding\
        // (HALF_UP)\
\
        private String formatAverage(long sum, int count) \{\
            if (count == 0)\
                return "0.0";\
            // Use Integer-based construction for exact precision, avoiding double\
            // representation errors\
            return java.math.BigDecimal.valueOf(sum)\
                    .divide(java.math.BigDecimal.valueOf(count), 1, java.math.RoundingMode.HALF_UP)\
                    .toString();\
        \}\
\
        // Precomputes Articulation Points and Bridges using Iterative Tarjan's\
        // Algorithm.\
        private void precomputeCriticalities() \{\
            if (!criticalitiesDirty)\
                return;\
\
            int n = hostCount;\
            int estimatedStackSize = n * 2;\
\
            // Adjust capacity logic to pre-size\
            if (disc == null || disc.length < n) \{\
                int cap = Math.max(n, INITIAL_HOST_CAP);\
                disc = new int[cap];\
                low = new int[cap];\
                apComponentIncrease = new int[cap];\
                tarjanStack = new int[cap * 4];\
                childCount = new int[cap];\
                visitedToken = new int[cap];\
            \}\
            if (tarjanStack.length < estimatedStackSize * 3) \{\
                tarjanStack = new int[estimatedStackSize * 3];\
            \}\
\
            if (isBridge == null || isBridge.length < edgeCount) \{\
                isBridge = new boolean[Math.max(edgeCount, INITIAL_EDGE_CAP)];\
            \}\
\
            // Token Management\
            globalToken++;\
            if (globalToken == 0) \{ // Overflow wrap-around (very rare)\
                globalToken = 1;\
                java.util.Arrays.fill(visitedToken, 0); // Clear all if wrapped\
            \}\
\
            // Reset critical arrays for bridges?\
            // Bridges are persistent properties.\
            // We must clear isBridge if graph changed.\
            // Since we don't have bridgeToken, we still do this.\
            // But only for current edges.\
            for (int i = 0; i < edgeCount; i++)\
                isBridge[i] = false;\
\
            time = 0;\
            int componentCount = 0;\
            boolean hasCycle = false;\
\
            // Iterative DFS stack\
            // Frames: [u, edge_ptr, parentEdge]\
            // parentEdge is the edge index used to arrive at u from parent. -1 for root.\
            int[] stack = tarjanStack;\
            int top = 0;\
\
            for (int i = 0; i < n; i++) \{\
                // If visited in current run, skip\
                if (visitedToken[i] == globalToken)\
                    continue;\
\
                componentCount++;\
                // Push root 'i'\
                stack[top++] = i;\
                stack[top++] = head[i];\
                stack[top++] = -1;\
\
                // Initialize root AP count (needed since array is dirty from prev runs)\
                // Actually we just write to it at the end.\
                // But safety init:\
                apComponentIncrease[i] = 0;\
\
                while (top > 0) \{\
                    int pe = stack[top - 1]; // parentEdge\
                    int e = stack[top - 2]; // current edge ptr\
                    int u = stack[top - 3]; // current node\
\
                    if (visitedToken[u] != globalToken) \{\
                        visitedToken[u] = globalToken;\
                        disc[u] = low[u] = ++time;\
                        childCount[u] = 0;\
                        apComponentIncrease[u] = 0; // Clear dirty value\
                    \}\
\
                    int p = (pe == -1) ? -1 : to[edgePartner[pe]];\
\
                    boolean pushedChild = false;\
                    while (e != -1) \{\
                        if (sealed[e]) \{\
                            e = next[e];\
                            continue;\
                        \}\
\
                        // Multigraph handling:\
                        // Only ignore the exact edge we came from (reverse of pe).\
                        if (pe != -1 && e == edgePartner[pe]) \{\
                            e = next[e];\
                            continue;\
                        \}\
\
                        int v = to[e];\
                        if (visitedToken[v] == globalToken) \{\
                            // Back-edge (or parallel edge to parent) -> Cycle detected\
                            // Only if v is in stack (ancestor). In standard Tarjan undirected,\
                            // if v is visited and not parent, it's a back edge.\
                            // With bridges, disc[v] < disc[u] check is implied if visited.\
                            hasCycle = true;\
                            low[u] = Math.min(low[u], disc[v]);\
                            e = next[e];\
                        \} else \{\
                            // Tree-edge to v\
                            stack[top - 2] = next[e]; // Save state of u\
\
                            // Push v with 'e' as parentEdge\
                            stack[top++] = v;\
                            stack[top++] = head[v];\
                            stack[top++] = e;\
                            pushedChild = true;\
                            break;\
                        \}\
                    \}\
\
                    if (!pushedChild) \{\
                        // Finished u, backtrack\
                        top -= 3; // Pop u\
\
                        if (p != -1) \{\
                            // Returning to parent p from child u\
                            low[p] = Math.min(low[p], low[u]);\
                            childCount[p]++;\
\
                            // AP Check (Non-root)\
                            if (low[u] >= disc[p]) \{\
                                apComponentIncrease[p]++;\
                            \}\
\
                            // Bridge Check\
                            if (low[u] > disc[p]) \{\
                                // The edge we came from (pe) IS a bridge.\
                                isBridge[pe] = true;\
                                isBridge[edgePartner[pe]] = true;\
                            \}\
                        \}\
                    \}\
                \}\
\
                // Root check\
                if (childCount[i] > 1) \{\
                    apComponentIncrease[i] = childCount[i] - 1;\
                \} else \{\
                    apComponentIncrease[i] = 0;\
                \}\
            \}\
            criticalitiesDirty = false;\
\
            // Optimization: Update cachedGraphInfo avoiding redundant analyzeGraph() call\
            if (cachedGraphInfo == null)\
                cachedGraphInfo = new GraphInfo();\
            cachedGraphInfo.components = componentCount;\
            cachedGraphInfo.hasCycle = hasCycle;\
        \}\
\
        private int getComponentCount() \{\
            return getGraphInfo().components;\
        \}\
\
        private GraphInfo getGraphInfo() \{\
            if (graphInfoDirty) \{\
                // Tarjan computes everything (Components, Cycles).\
                // It updates cachedGraphInfo.\
                precomputeCriticalities();\
\
                // If precompute didn't run because it thought criticalities weren't dirty,\
                // but graphInfo IS dirty (shouldn't happen if dirty logic is synced),\
                // we force it.\
                if (cachedGraphInfo == null) \{\
                    criticalitiesDirty = true;\
                    precomputeCriticalities();\
                \}\
                // Just in case precompute didn't clear graphInfoDirty (it should have):\
                graphInfoDirty = false;\
            \}\
            return cachedGraphInfo;\
        \}\
\
        private void markGraphDirty() \{\
            graphInfoDirty = true;\
            criticalitiesDirty = true;\
        \}\
