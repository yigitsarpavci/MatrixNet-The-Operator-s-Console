        // Multi-objective Dijkstra: minimizes cost (lambda-adjusted latency),\
        // then hop count, then lexicographical order.\
        // This method is now part of the Router class for thread-local state.\
        // private RouteResult findRoute(int source, int dest, int minBw, int lambda) \{\
        // ... \}\
\
        record TraceRequest(int source, int dest, int minBw, int lambda) \{\
        \}\
\
        private class Router \{\
            final MatrixNet graph;\
            final PrimitiveRouteStateHeap pq;\
            BestStatePool bestPool;\
            int[] bestHead;\
            int[] bestRunId;\
            int routeSearchId = 0;\
            final StringBuilder sb = new StringBuilder(512);\
\
            Router(MatrixNet graph) \{\
                this.graph = graph;\
                this.pq = new PrimitiveRouteStateHeap();\
                // Pool and arrays init lazily\
            \}\
\
            String executeTrace(int source, int dest, int minBw, int lambda, String[] hostIds) \{\
                sb.setLength(0);\
                if (source == -1 || dest == -1) \{\
                    sb.append("Some error occurred in trace_route.");\
                    return sb.toString();\
                \}\
                if (source == dest) \{\
                    sb.append("Optimal route ").append(hostIds[source]).append(" -> ").append(hostIds[dest])\
                            .append(": ").append(hostIds[source]).append(" (Latency = 0ms)");\
                    return sb.toString();\
                \}\
\
                RouteResult result = findRoute(source, dest, minBw, lambda);\
\
                if (!result.found) \{\
                    sb.append("No route found from ").append(hostIds[source]).append(" to ").append(hostIds[dest]);\
                \} else \{\
                    sb.append("Optimal route ").append(hostIds[source]).append(" -> ").append(hostIds[dest])\
                            .append(": ");\
\
                    // Zero-Allocation Path Reconstruction\
                    int current = result.endStateIdx;\
                    int pathLen = 0;\
                    int[] stack = pq.pathBufferA; // Router has its own PQ has its own buffers\
\
                    while (current != -1) \{\
                        if (pathLen >= stack.length) \{\
                            int[] newStack = new int[stack.length * 2];\
                            System.arraycopy(stack, 0, newStack, 0, stack.length);\
                            stack = newStack;\
                            pq.pathBufferA = stack;\
                        \}\
                        stack[pathLen++] = pq.poolU[current];\
                        current = pq.poolPrev[current];\
                    \}\
\
                    for (int i = pathLen - 1; i >= 0; i--) \{\
                        if (i < pathLen - 1)\
                            sb.append(" -> ");\
                        sb.append(hostIds[stack[i]]);\
                    \}\
                    sb.append(" (Latency = ").append(result.cost).append("ms)");\
                \}\
                return sb.toString();\
            \}\
\
            // Wrapper for Dijkstra\
            private RouteResult findRoute(int source, int dest, int minBw, int lambda) \{\
                // IMPORTANT: updateHostRanks() called by caller (flushTraceBuffer)\
\
                int estimatedStates = Math.max(4096, graph.hostCount * 4);\
                pq.ensureCapacity(estimatedStates);\
                pq.reset();\
\
                if (bestHead == null || bestHead.length < graph.hostCount) \{\
                    int cap = Math.max(graph.hostCount, 1024);\
                    bestHead = new int[cap];\
                    for (int i = 0; i < cap; i++)\
                        bestHead[i] = -1;\
                    bestRunId = new int[cap];\
                \}\
                if (bestPool == null) \{\
                    int initialPoolCap = Math.max(100000, graph.hostCount * 4);\
                    bestPool = new BestStatePool(initialPoolCap);\
                \} else \{\
                    bestPool.reset();\
                \}\
\
                routeSearchId++;\
                int startIdx = pq.allocState(source, 0, 0, -1);\
\
                if (bestRunId[source] != routeSearchId) \{\
                    bestHead[source] = -1;\
                    bestRunId[source] = routeSearchId;\
                \}\
                bestHead[source] = bestPool.alloc(0, 0, startIdx, bestHead[source]);\
                pq.add(startIdx);\
\
                int bestCost = Integer.MAX_VALUE;\
                int bestStateIdx = -1;\
                int bestEdges = Integer.MAX_VALUE;\
\
                while (!pq.isEmpty()) \{\
                    int stateIdx = pq.poll();\
                    int u = pq.poolU[stateIdx];\
                    int cost = pq.poolCost[stateIdx];\
                    int edges = pq.poolEdges[stateIdx];\
\
                    if (cost > bestCost || (cost == bestCost && edges > bestEdges))\
                        continue;\
\
                    boolean dominated = false;\
                    if (bestRunId[u] == routeSearchId) \{\
                        for (int i = bestHead[u]; i != -1; i = bestPool.next[i]) \{\
                            int c = bestPool.costs[i];\
                            int e = bestPool.edges[i];\
                            if (c <= cost && e <= edges) \{\
                                if (c < cost || e < edges) \{\
                                    dominated = true;\
                                    break;\
                                \} else \{\
                                    if (bestPool.stateIndices[i] != stateIdx) \{\
                                        dominated = true;\
                                        break;\
                                    \}\
                                \}\
                            \}\
                        \}\
                    \}\
                    if (dominated)\
                        continue;\
\
                    if (u == dest) \{\
                        if (cost < bestCost) \{\
                            bestCost = cost;\
                            bestEdges = edges;\
                            bestStateIdx = stateIdx;\
                        \} else \{\
                            if (edges < bestEdges) \{\
                                bestEdges = edges;\
                                bestStateIdx = stateIdx;\
                            \} else if (edges == bestEdges) \{\
                                if (bestStateIdx == -1)\
                                    bestStateIdx = stateIdx;\
                                else \{\
                                    if (pq.compareStatePaths(stateIdx, bestStateIdx) < 0) \{\
                                        bestStateIdx = stateIdx;\
                                    \}\
                                \}\
                            \}\
                        \}\
                        continue;\
                    \}\
\
                    // Access fields from outer MatrixNet using graph instance\
                    for (int e = graph.head[u]; e != -1; e = graph.next[e]) \{\
                        if (graph.sealed[e] || graph.bandwidth[e] < minBw)\
                            continue;\
                        if (graph.hostClearance[u] < graph.firewall[e])\
                            continue; // Using hostClearance from graph\
\
                        int lambdaPenalty = 0;\
                        if (lambda != 0) \{\
                            lambdaPenalty = lambda * edges;\
                        \}\
                        int newCost = cost + graph.latency[e] + lambdaPenalty;\
                        int newEdges = edges + 1;\
\
                        int v = graph.to[e];\
\
                        if (bestRunId[v] != routeSearchId) \{\
                            bestHead[v] = -1;\
                            bestRunId[v] = routeSearchId;\
                        \}\
                        boolean innerDominated = false;\
                        for (int i = bestHead[v]; i != -1; i = bestPool.next[i]) \{\
                            if (bestPool.costs[i] <= newCost && bestPool.edges[i] <= newEdges) \{\
                                innerDominated = true;\
                                break;\
                            \}\
                        \}\
                        if (innerDominated)\
                            continue;\
\
                        int newStateIdx = pq.allocState(v, newCost, newEdges, stateIdx);\
                        bestHead[v] = bestPool.alloc(newCost, newEdges, newStateIdx, bestHead[v]);\
                        pq.add(newStateIdx);\
                    \}\
                \}\
                if (bestStateIdx == -1)\
                    return RouteResult.notFound();\
                return new RouteResult(true, bestCost, bestStateIdx);\
            \}\
        \}\
\
        private void handleScanConnectivity(BufferedWriter writer) throws IOException \{\
            flushTraceBuffer(writer);\
            if (hostCount <= 1) \{\
                writer.write("Network is fully connected.");\
                writer.newLine();\
                return;\
            \}\
            int components = getComponentCount();\
\
            if (components == 1) \{\
                writer.write("Network is fully connected.");\
            \} else \{\
                logBuffer.setLength(0);\
                logBuffer.append("Network has ").append(components).append(" disconnected components.");\
                writer.append(logBuffer);\
            \}\
            writer.newLine();\
        \}\
