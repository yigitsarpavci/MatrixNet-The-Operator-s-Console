        // Specialized QuickSort for host integers.\
        // Sorts 'indices' array based on the String IDs in 'hostIds'.\
        // Avoids Boxing/Unboxing of Integer objects.\
        private void quickSortIndices(int[] indices, int low, int high) \{\
            if (low < high) \{\
                int pi = partitionIndices(indices, low, high);\
                quickSortIndices(indices, low, pi - 1);\
                quickSortIndices(indices, pi + 1, high);\
            \}\
        \}\
\
        private int partitionIndices(int[] indices, int low, int high) \{\
            // Use Middle Element as pivot to handle sorted inputs efficiently\
            // without the overhead of Math.random() initialization\
            int pivotIndex = (low + high) >>> 1;\
\
            // Swap pivot to end\
            int tempP = indices[pivotIndex];\
            indices[pivotIndex] = indices[high];\
            indices[high] = tempP;\
\
            String pivot = hostIds[indices[high]];\
            int i = (low - 1);\
            for (int j = low; j < high; j++) \{\
                if (hostIds[indices[j]].compareTo(pivot) < 0) \{\
                    i++;\
                    int temp = indices[i];\
                    indices[i] = indices[j];\
                    indices[j] = temp;\
                \}\
            \}\
            int temp = indices[i + 1];\
            indices[i + 1] = indices[high];\
            indices[high] = temp;\
            return i + 1;\
        \}\
\
        private static class HostMap \{\
            // Open addressing linear probing\
            // Keys are kept as Strings for result printing, but lookups can happen via\
            // byte[]\
            private static final int INITIAL_CAPACITY = 2048;\
            private static final float LOAD_FACTOR = 0.75f;\
\
            private String[] keys;\
            private int[] values;\
            private int size;\
            private int threshold;\
\
            HostMap() \{\
                int cap = INITIAL_CAPACITY;\
                keys = new String[cap];\
                values = new int[cap];\
                java.util.Arrays.fill(values, -1);\
                threshold = (int) (cap * LOAD_FACTOR);\
            \}\
\
            void put(String key, int value) \{\
                if (size >= threshold)\
                    resize();\
                int mask = keys.length - 1;\
                int h = key.hashCode();\
                h = h ^ (h >>> 16);\
                int idx = h & mask;\
\
                while (keys[idx] != null) \{\
                    if (keys[idx].equals(key))\
                        return; // exists\
                    idx = (idx + 1) & mask;\
                \}\
                keys[idx] = key;\
                values[idx] = value;\
                size++;\
            \}\
\
            // Standard String get\
            int get(String key) \{\
                int mask = keys.length - 1;\
                int h = key.hashCode();\
                h = h ^ (h >>> 16);\
                int idx = h & mask;\
\
                while (keys[idx] != null) \{\
                    if (keys[idx].equals(key))\
                        return values[idx];\
                    idx = (idx + 1) & mask;\
                \}\
                return -1;\
            \}\
\
            boolean contains(String key) \{\
                return get(key) != -1;\
            \}\
\
            // Zero-Alloc Byte Lookup\
            int get(byte[] buffer, int start, int len) \{\
                int mask = keys.length - 1;\
                // Djb2 or similar simple hash for bytes that matches String hash?\
                // Java String hash is s[0]*31^(n-1) + ...\
                // We must match String.hashCode() exactly to find the key inserted as String\
                int h = 0;\
                for (int i = 0; i < len; i++) \{\
                    h = 31 * h + (buffer[start + i] & 0xFF);\
                \}\
                h = h ^ (h >>> 16);\
                int idx = h & mask;\
\
                while (keys[idx] != null) \{\
                    String k = keys[idx];\
                    if (k.length() == len) \{\
                        boolean match = true;\
                        for (int i = 0; i < len; i++) \{\
                            if ((byte) k.charAt(i) != buffer[start + i]) \{\
                                match = false;\
                                break;\
                            \}\
                        \}\
                        if (match)\
                            return values[idx];\
                    \}\
                    idx = (idx + 1) & mask;\
                \}\
                return -1;\
            \}\
\
            private void resize() \{\
                int oldCap = keys.length;\
                int newCap = oldCap << 1;\
                int mask = newCap - 1;\
\
                String[] newKeys = new String[newCap];\
                int[] newValues = new int[newCap];\
                java.util.Arrays.fill(newValues, -1);\
\
                for (int i = 0; i < oldCap; i++) \{\
                    if (keys[i] != null) \{\
                        String k = keys[i];\
                        int v = values[i];\
                        int h = k.hashCode();\
                        h = h ^ (h >>> 16);\
                        int idx = h & mask;\
                        while (newKeys[idx] != null) \{\
                            idx = (idx + 1) & mask;\
                        \}\
                        newKeys[idx] = k;\
                        newValues[idx] = v;\
                    \}\
                \}\
                keys = newKeys;\
                values = newValues;\
                threshold = (int) (newCap * LOAD_FACTOR);\
            \}\
        \}\
\
        private static class ConnectionMap \{\
            private static final int INITIAL_CAPACITY = 2048;\
            private static final float LOAD_FACTOR = 0.75f;\
            private ConnEntry[] table;\
            private int size;\
            private int threshold;\
\
            ConnectionMap() \{\
                table = new ConnEntry[INITIAL_CAPACITY];\
                threshold = (int) (INITIAL_CAPACITY * LOAD_FACTOR);\
            \}\
\
            void put(long key, int value) \{\
                if (size >= threshold)\
                    resize();\
                int h = Long.hashCode(key);\
                h = h ^ (h >>> 16);\
                int index = (h & 0x7FFFFFFF) % table.length;\
                ConnEntry head = table[index];\
                ConnEntry current = head;\
                while (current != null) \{\
                    if (current.key == key)\
                        return;\
                    current = current.next;\
                \}\
                table[index] = new ConnEntry(key, value, head);\
                size++;\
            \}\
\
            int get(long key) \{\
                int h = Long.hashCode(key);\
                h = h ^ (h >>> 16);\
                int index = (h & 0x7FFFFFFF) % table.length;\
                ConnEntry current = table[index];\
                while (current != null) \{\
                    if (current.key == key)\
                        return current.value;\
                    current = current.next;\
                \}\
                return -1;\
            \}\
\
            boolean contains(long key) \{\
                return get(key) != -1;\
            \}\
\
            private void resize() \{\
                int newCap = table.length * 2;\
                ConnEntry[] newTable = new ConnEntry[newCap];\
                for (ConnEntry e : table) \{\
                    while (e != null) \{\
                        ConnEntry next = e.next;\
                        int h = Long.hashCode(e.key);\
                        h = h ^ (h >>> 16);\
                        int index = (h & 0x7FFFFFFF) % newCap;\
                        e.next = newTable[index];\
                        newTable[index] = e;\
                        e = next;\
                    \}\
                \}\
                table = newTable;\
                threshold = (int) (newCap * LOAD_FACTOR);\
            \}\
\
            static class ConnEntry \{\
                final long key;\
                final int value;\
                ConnEntry next;\
\
                ConnEntry(long key, int value, ConnEntry next) \{\
                    this.key = key;\
                    this.value = value;\
                    this.next = next;\
                \}\
            \}\
        \}\
\
        // Helper class for parsing input lines without String.split()\
        // Reduces temporary String allocation.\
        // Fast Byte Scanner using System.in\
        private static class FastByteScanner \{\
            private final java.io.InputStream in;\
            private final byte[] buffer = new byte[16384];\
            private int ptr = 0;\
            private int buflen = 0;\
\
            // Exposed for Map Lookups\
            byte[] cmdBuffer = new byte[256]; // Temp buffer for parsing tokens if needed across boundaries?\
            // Actually, we can just return a pointer into 'buffer' if the token is\
            // contiguous.\
            // If split, we copy to 'cmdBuffer'.\
\
            // We'll use a dedicated token buffer for "current token" to simplify logic\
            byte[] tokenBuf = new byte[256];\
            int tokenLen = 0;\
\
            FastByteScanner(java.io.InputStream in) \{\
                this.in = in;\
            \}\
\
            private boolean hasNextByte() \{\
                if (ptr < buflen)\
                    return true;\
                ptr = 0;\
                try \{\
                    buflen = in.read(buffer);\
                \} catch (IOException e) \{\
                    return false;\
                \}\
                return buflen > 0;\
            \}\
\
            private byte readByte() \{\
                if (hasNextByte())\
                    return buffer[ptr++];\
                return -1;\
            \}\
\
            boolean nextToken() \{\
                tokenLen = 0;\
                while (hasNextByte()) \{\
                    byte b = buffer[ptr];\
                    if (b <= ' ') \{\
                        ptr++;\
                    \} else \{\
                        break;\
                    \}\
                \}\
                if (!hasNextByte())\
                    return false;\
\
                // Read token\
                while (hasNextByte()) \{\
                    byte b = buffer[ptr];\
                    if (b <= ' ')\
                        break;\
                    if (tokenLen >= tokenBuf.length) \{\
                        byte[] newBuf = new byte[tokenBuf.length * 2];\
                        System.arraycopy(tokenBuf, 0, newBuf, 0, tokenBuf.length);\
                        tokenBuf = newBuf;\
                    \}\
                    tokenBuf[tokenLen++] = b;\
                    ptr++;\
                \}\
                return tokenLen > 0;\
            \}\
\
            String currentString() \{\
                return new String(tokenBuf, 0, tokenLen, java.nio.charset.StandardCharsets.US_ASCII);\
            \}\
\
            int currentInt() \{\
                int val = 0;\
                for (int i = 0; i < tokenLen; i++) \{\
                    val = val * 10 + (tokenBuf[i] - '0');\
                \}\
                return val;\
            \}\
\
            boolean matchCommand(String cmd) \{\
                if (tokenLen != cmd.length())\
                    return false;\
                for (int i = 0; i < tokenLen; i++) \{\
                    if (tokenBuf[i] != (byte) cmd.charAt(i))\
                        return false;\
                \}\
                return true;\
            \}\
\
            boolean nextTokenSameLine() \{\
                tokenLen = 0;\
                while (hasNextByte()) \{\
                    byte b = buffer[ptr];\
                    if (b <= ' ') \{\
                        if (b == '\\n')\
                            return false; // Newline barrier\
                        ptr++;\
                    \} else \{\
                        break;\
                    \}\
                \}\
                if (!hasNextByte())\
                    return false;\
\
                // Read token\
                while (hasNextByte()) \{\
                    byte b = buffer[ptr];\
                    if (b <= ' ')\
                        break;\
                    if (tokenLen >= tokenBuf.length) \{\
                        byte[] newBuf = new byte[tokenBuf.length * 2];\
                        System.arraycopy(tokenBuf, 0, newBuf, 0, tokenBuf.length);\
                        tokenBuf = newBuf;\
                    \}\
                    tokenBuf[tokenLen++] = b;\
                    ptr++;\
                \}\
                return tokenLen > 0;\
            \}\
        \}\
    \}\
\}\
}