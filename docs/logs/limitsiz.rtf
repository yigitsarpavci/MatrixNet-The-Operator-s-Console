        // Pool for storing the Pareto frontier of best states for each node.\
        // Each node maintains a linked list of non-dominated (Cost, Edges) pairs.\
        private static class BestStatePool \{\
            int[] costs; // Optimized to int (Max cost ~100M < 2B)\
            int[] edges;\
            int[] stateIndices; // Store the PQ state index for this Pareto point\
            int[] next;\
            int ptr = 0;\
\
            BestStatePool(int initialCap) \{\
                costs = new int[initialCap];\
                edges = new int[initialCap];\
                stateIndices = new int[initialCap];\
                next = new int[initialCap];\
            \}\
\
            int alloc(int cost, int edge, int stateIdx, int nextIdx) \{\
                if (ptr >= costs.length)\
                    resize();\
                int idx = ptr++;\
                costs[idx] = cost;\
                edges[idx] = edge;\
                stateIndices[idx] = stateIdx;\
                next[idx] = nextIdx;\
                return idx;\
            \}\
\
            void reset() \{\
                ptr = 0;\
            \}\
\
            private void resize() \{\
                int newCap = costs.length * 2;\
                int[] newCosts = new int[newCap];\
                System.arraycopy(costs, 0, newCosts, 0, costs.length);\
                costs = newCosts;\
                int[] newEdges = new int[newCap];\
                System.arraycopy(edges, 0, newEdges, 0, edges.length);\
                edges = newEdges;\
                int[] newStateIndices = new int[newCap];\
                System.arraycopy(stateIndices, 0, newStateIndices, 0, stateIndices.length);\
                stateIndices = newStateIndices;\
                int[] newNext = new int[newCap];\
                System.arraycopy(next, 0, newNext, 0, next.length);\
                next = newNext;\
            \}\
        \}\
\
        // Custom RouteStateHeap using primitive arrays to avoid object overhead.\
        // Acts as a Priority Queue for Dijkstra states.\
        private class PrimitiveRouteStateHeap \{\
            int[] heap; // Stores indices into the 'pool' arrays\
            int size = 0;\
\
            // Pool arrays to store state data (U, Cost, Edges, PrevState)\
            // This pooling mechanism drastically reduces GC pressure.\
            int[] poolU;\
            int[] poolCost; // Optimized to int\
            int[] poolEdges;\
            int[] poolPrev;\
            int poolPtr = 0;\
\
            int[] pathBufferA = new int[1024];\
            int[] pathBufferB = new int[1024];\
\
            PrimitiveRouteStateHeap() \{\
                int initCap = 4096;\
                poolU = new int[initCap];\
                poolCost = new int[initCap];\
                poolEdges = new int[initCap];\
                poolPrev = new int[initCap];\
                heap = new int[2048];\
            \}\
\
            void ensureCapacity(int needed) \{\
                if (poolU.length < needed) \{\
                    int newCap = Math.max(poolU.length * 2, needed);\
                    resizePool(newCap);\
                \}\
                if (heap.length < needed) \{\
                    int newCap = Math.max(heap.length * 2, needed);\
                    resizeHeap(newCap);\
                \}\
            \}\
\
            private void resizePool(int newCap) \{\
                int[] nu = new int[newCap];\
                System.arraycopy(poolU, 0, nu, 0, poolU.length);\
                poolU = nu;\
                int[] nc = new int[newCap];\
                System.arraycopy(poolCost, 0, nc, 0, poolCost.length);\
                poolCost = nc;\
                int[] ne = new int[newCap];\
                System.arraycopy(poolEdges, 0, ne, 0, poolEdges.length);\
                poolEdges = ne;\
                int[] np = new int[newCap];\
                System.arraycopy(poolPrev, 0, np, 0, poolPrev.length);\
                poolPrev = np;\
            \}\
\
            private void resizeHeap(int newCap) \{\
                int[] nh = new int[newCap];\
                System.arraycopy(heap, 0, nh, 0, heap.length);\
                heap = nh;\
            \}\
\
            int allocState(int u, int cost, int edges, int prev) \{\
                if (poolPtr >= poolU.length) \{\
                    resizePool(poolU.length * 2);\
                \}\
                int idx = poolPtr++;\
                poolU[idx] = u;\
                poolCost[idx] = cost;\
                poolEdges[idx] = edges;\
                poolPrev[idx] = prev;\
                return idx;\
            \}\
\
            void add(int stateIdx) \{\
                if (size >= heap.length) \{\
                    resizeHeap(heap.length * 2);\
                \}\
                heap[size] = stateIdx;\
                siftUp(size);\
                size++;\
            \}\
\
            int poll() \{\
                if (size == 0)\
                    return -1;\
                int ret = heap[0];\
                size--;\
                if (size > 0) \{\
                    heap[0] = heap[size];\
                    siftDown(0);\
                \}\
                heap[size] = -1;\
                return ret;\
            \}\
\
            boolean isEmpty() \{\
                return size == 0;\
            \}\
\
            void siftUp(int k) \{\
                int idx = heap[k];\
                int cost = poolCost[idx];\
                int edges = poolEdges[idx];\
\
                while (k > 0) \{\
                    int p = (k - 1) >>> 1;\
                    int pIdx = heap[p];\
                    int pCost = poolCost[pIdx];\
\
                    if (cost < pCost) \{\
                        heap[k] = pIdx;\
                        k = p;\
                    \} else if (cost > pCost) \{\
                        break;\
                    \} else \{ // cost == pCost\
                        int pEdges = poolEdges[pIdx];\
                        if (edges < pEdges) \{\
                            heap[k] = pIdx;\
                            k = p;\
                        \} else \{\
                            // Deterministic tie-breaking using Host Rank\
                            if (hostRank[poolU[idx]] < hostRank[poolU[pIdx]]) \{\
                                heap[k] = pIdx;\
                                k = p;\
                            \} else \{\
                                break;\
                            \}\
                        \}\
                    \}\
                \}\
                heap[k] = idx;\
            \}\
\
            void siftDown(int k) \{\
                int idx = heap[k];\
                int cost = poolCost[idx];\
                int edges = poolEdges[idx];\
                int half = size >>> 1;\
\
                while (k < half) \{\
                    int child = (k << 1) + 1;\
                    int cIdx = heap[child];\
                    int cCost = poolCost[cIdx];\
                    int cEdges = poolEdges[cIdx];\
\
                    int right = child + 1;\
                    if (right < size) \{\
                        int rIdx = heap[right];\
                        int rCost = poolCost[rIdx];\
                        int rEdges = poolEdges[rIdx];\
\
                        if (rCost < cCost) \{\
                            child = right;\
                            cIdx = rIdx;\
                            cCost = rCost;\
                            cEdges = rEdges;\
                        \} else if (rCost == cCost) \{\
                            if (rEdges < cEdges) \{\
                                child = right;\
                                cIdx = rIdx;\
                                cCost = rCost;\
                                cEdges = rEdges;\
                            \} else if (rEdges == cEdges) \{\
                                if (hostRank[poolU[rIdx]] < hostRank[poolU[cIdx]]) \{\
                                    child = right;\
                                    cIdx = rIdx;\
                                    cCost = rCost;\
                                    cEdges = rEdges;\
                                \}\
                            \}\
                        \}\
                    \}\
\
                    if (cost < cCost)\
                        break;\
                    if (cost == cCost && edges < cEdges)\
                        break;\
                    if (cost == cCost && edges == cEdges && hostRank[poolU[idx]] <= hostRank[poolU[cIdx]])\
                        break;\
\
                    heap[k] = cIdx;\
                    k = child;\
                \}\
                heap[k] = idx;\
            \}\
\
            void reset() \{\
                size = 0;\
                poolPtr = 0;\
            \}\
\
            // Zero-Allocation Lexicographical Comparison\
            int compareStatePaths(int stateIdxA, int stateIdxB) \{\
                int lenA = 0;\
                int cur = stateIdxA;\
                while (cur != -1) \{\
                    if (lenA >= pathBufferA.length) \{\
                        pathBufferA = resizeBuffer(pathBufferA);\
                    \}\
                    pathBufferA[lenA++] = poolU[cur];\
                    cur = poolPrev[cur];\
                \}\
\
                int lenB = 0;\
                cur = stateIdxB;\
                while (cur != -1) \{\
                    if (lenB >= pathBufferB.length) \{\
                        pathBufferB = resizeBuffer(pathBufferB);\
                    \}\
                    pathBufferB[lenB++] = poolU[cur];\
                    cur = poolPrev[cur];\
                \}\
\
                // Reverse compare (Root -> Leaf)\
                // pathBuffer contains [Leaf, ..., Root]\
                int i = lenA - 1;\
                int j = lenB - 1;\
                while (i >= 0 && j >= 0) \{\
                    int uA = pathBufferA[i];\
                    int uB = pathBufferB[j];\
                    if (uA != uB) \{\
                        // hostRank available because inner class\
                        return Integer.compare(hostRank[uA], hostRank[uB]);\
                    \}\
                    i--;\
                    j--;\
                \}\
                return Integer.compare(lenA, lenB);\
            \}\
\
            private int[] resizeBuffer(int[] oldBuf) \{\
                int[] newBuf = new int[oldBuf.length * 2];\
                System.arraycopy(oldBuf, 0, newBuf, 0, oldBuf.length);\
                return newBuf;\
            \}\
        \}\
\
        private void updateHostRanks() \{\
            if (!hostsDirtyRanks)\
                return;\
            int[] indices = new int[hostCount];\
            for (int i = 0; i < hostCount; i++)\
                indices[i] = i;\
\
            quickSortIndices(indices, 0, hostCount - 1);\
\
            if (hostRank == null || hostRank.length < hostCount) \{\
                hostRank = new int[Math.max(hostCount, hostIds.length)];\
            \}\
            for (int i = 0; i < hostCount; i++) \{\
                hostRank[indices[i]] = i;\
            \}\
            hostsDirtyRanks = false;\
        \}\
