        private boolean isValidHostId(String id) \{\
            if (id == null || id.isEmpty())\
                return false;\
            int len = id.length();\
            for (int i = 0; i < len; i++) \{\
                char c = id.charAt(i);\
                if (!((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '_'))\
                    return false;\
            \}\
            return true;\
        \}\
